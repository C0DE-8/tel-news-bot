TELEGRAM_BOT_TOKEN=123456789:your_bot_token_here

# Optional
POST_INTERVAL_MINUTES=30
PORT=3000

# Use polling by default. Set true only after you configure Telegram setWebhook.
TELEGRAM_USE_WEBHOOK=false

# Optional: comma-separated Telegram user ids allowed to manage news settings.
# Send /adminid to the bot to see your id.
TELEGRAM_ADMIN_CHAT_IDS=123456789

# Optional but recommended on Vercel: comma-separated group ids.
# Format: chat_id|display name,chat_id|display name
TELEGRAM_GROUP_CHAT_IDS=-1001234567890|Main News Group
